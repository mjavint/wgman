# ── Authentication ────────────────────────────────────────────────────────────
DISABLE_LOGIN=false
WGUI_USERNAME=admin
WGUI_PASSWORD=admin
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-in-production

# ── Server networking ─────────────────────────────────────────────────────────
# Public IP or hostname clients will use to reach the VPN server
WGUI_ENDPOINT_ADDRESS=192.168.1.1
WGUI_PUBLIC_URL=http://localhost:5001

# ── WireGuard interface ───────────────────────────────────────────────────────
WGUI_CONFIG_FILE_PATH=/app/db/wg0.conf
WGUI_SERVER_LISTEN_PORT=51820
WGUI_SERVER_INTERFACE_ADDRESSES=10.252.1.0/24
WGUI_DNS=8.8.8.8,8.8.4.4
WGUI_MTU=1420
WGUI_PERSISTENT_KEEPALIVE=25
WGUI_TABLE=auto
# WGUI_FIREWALL_MARK=

# Post-up/down iptables rules.
# $(ip route show default | awk '{print $5}' | head -1) detects the outbound
# interface at runtime so the NAT rule works regardless of interface name (eth0, ens3, etc.)
# wg-quick executes these scripts via bash, so subshell commands work correctly.
WGUI_SERVER_POST_UP_SCRIPT=sysctl -w net.ipv4.ip_forward=1; iptables -A FORWARD -i %i -j ACCEPT; iptables -A FORWARD -o %i -j ACCEPT; iptables -t nat -A POSTROUTING -o $(ip route show default | awk '{print $5}' | head -1) -j MASQUERADE
WGUI_SERVER_POST_DOWN_SCRIPT=iptables -D FORWARD -i %i -j ACCEPT; iptables -D FORWARD -o %i -j ACCEPT; iptables -t nat -D POSTROUTING -o $(ip route show default | awk '{print $5}' | head -1) -j MASQUERADE

# ── Interface lifecycle ───────────────────────────────────────────────────────
WGUI_MANAGE_START=true
WGUI_MANAGE_RESTART=true

# ── Email (optional) ──────────────────────────────────────────────────────────
# SendGrid (takes priority over SMTP when set)
# SENDGRID_API_KEY=
# EMAIL_FROM_ADDRESS=noreply@example.com
# EMAIL_FROM_NAME=WireGuard Manager

# SMTP (used when SENDGRID_API_KEY is not set)
# SMTP_HOSTNAME=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_ENCRYPTION=STARTTLS   # NONE | SSL | SSLTLS | TLS | STARTTLS
# SMTP_AUTH_TYPE=PLAIN        # PLAIN | LOGIN | NONE

# ── Telegram bot (optional) ───────────────────────────────────────────────────
# TELEGRAM_TOKEN=
# TELEGRAM_ALLOW_CONF_REQUEST=false
# TELEGRAM_FLOOD_WAIT=60

# ── Advanced ──────────────────────────────────────────────────────────────────
# SUBNET_RANGES=
# BASE_PATH=
# SESSION_MAX_DURATION=90
